# Database
MONGODB_URI=mongodb://127.0.0.1:27017/toms
# Optional dedicated read-only backup user/URI for mongodump and GitHub Actions
MONGODB_BACKUP_URI=
# Optional dedicated restore target. Prefer a local/staging database, not production.
MONGODB_RESTORE_URI=

# Application URLs
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Authentication
JWT_SECRET=change-me-to-a-256-bit-secret-key-in-production
JWT_EXPIRES_IN=1d

# Contact / chat widgets
WHATSAPP_NUMBER=94704239802
NEXT_PUBLIC_WHATSAPP_NUMBER=94704239802
NEXT_PUBLIC_TAWKTO_PROPERTY_ID=your-tawk-property-id
NEXT_PUBLIC_TAWKTO_WIDGET_ID=your-tawk-widget-id

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Yatara Ceylon <noreply@example.com>"

# Payment Gateway - Stripe (server-side hooks only in current app)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=lkr

# Payment Gateway - PayHere
PAYHERE_MODE=sandbox
PAYHERE_MERCHANT_ID=your_merchant_id
PAYHERE_MERCHANT_SECRET=your_merchant_secret
# Optional domain-specific/live secret variants used by the current config helper
PAYHERE_MERCHANT_SECRET_PROD=
PAYHERE_MERCHANT_SECRET_WWW=
PAYHERE_APP_ID=
PAYHERE_APP_SECRET=
PAYHERE_CURRENCY=LKR
